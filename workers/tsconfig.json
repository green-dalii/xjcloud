{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types"],
    "outDir": "./dist",
    "rootDir": "..",
    "paths": {
      "drizzle-orm": ["./node_modules/drizzle-orm"]
    }
  },
  "include": ["src/**/*", "../lib/db/schema.ts"],
  "exclude": ["node_modules", "dist"]
}
