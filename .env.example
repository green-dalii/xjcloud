# ============================================
# 乡建协作平台 (xjcloud) — 环境变量模板
# 复制此文件为 .env.local 后填入实际值
# .env*.local 不会被提交到 Git（见 .gitignore）
# ============================================

# ── NextAuth.js 认证 ──
# 生产环境必需：用于 JWT 签名和会话加密
# 生成方式：openssl rand -base64 32
AUTH_SECRET=

# 认证回调基础 URL（生产环境必需）
# 本地开发可留空，Next.js 自动推断
NEXTAUTH_URL=http://localhost:3001

# ── 数据库 ──
# SQLite 本地路径（开发环境）
# Cloudflare D1 生产环境：通过 wrangler.toml / Dashboard 配置
DATABASE_URL=./xjcloud.db

# ── LLM / AI ──
# LLM API Key，用于 AI 活动方案生成等数据处理
# 支持 Anthropic (Claude) 或 OpenAI
LLM_API_KEY=

# LLM 提供商：anthropic | openai
LLM_PROVIDER=anthropic

# 具体模型名称
# Anthropic: claude-sonnet-4-6, claude-opus-4-7
# OpenAI: gpt-4o, gpt-4o-mini
LLM_MODEL=claude-sonnet-4-6

# ── Cloudflare 部署（可选）──
# Cloudflare Account ID（wrangler 部署用）
# CLOUDFLARE_ACCOUNT_ID=

# Cloudflare D1 Database ID（生产数据库）
# CLOUDFLARE_D1_DATABASE_ID=
